# ============================================================
# StackSQScanner Configuration
# ============================================================
# Copy this file to .env and customize as needed.
# All values shown are the defaults - uncomment and modify to override.
# ============================================================

# ------------------------------------------------------------
# TOOL INFORMATION (appears in SBOM metadata)
# ------------------------------------------------------------
SBOM_TOOL_NAME=StackSQScanner
SBOM_TOOL_VENDOR=SISA Information Security Pvt. Ltd
SBOM_TOOL_VERSION=1.0.0
SBOM_TOOL_AUTHOR=SISA Security Team
SBOM_TOOL_URL=https://github.com/SISA-Security/StackSQScanner
# ------------------------------------------------------------
# OUTPUT SETTINGS
# ------------------------------------------------------------
# Directory for scan reports (relative or absolute path)
SBOM_REPORTS_DIR=reports
# Temporary files directory
SBOM_TEMP_DIR=temp
# Default SBOM format: cyclonedx, spdx, or json
SBOM_SBOM_FORMAT=cyclonedx
# Generate all SBOM formats (true/false)
SBOM_GENERATE_ALL_FORMATS=true

# ------------------------------------------------------------
# API ENDPOINTS (override for private/enterprise instances)
# ------------------------------------------------------------
# PyPI Registry
SBOM_PYPI_URL=https://pypi.org/project
SBOM_PYPI_API=https://pypi.org/pypi

# NPM Registry
SBOM_NPM_URL=https://www.npmjs.com/package
SBOM_NPM_API=https://registry.npmjs.org

# Vulnerability Databases
SBOM_OSV_API=https://api.osv.dev/v1
SBOM_NVD_API=https://services.nvd.nist.gov/rest/json/cve/1.0
# Git Hosting APIs
SBOM_GITHUB_API=https://api.github.com
SBOM_GITLAB_API=https://gitlab.com/api/v4

# Other APIs
SBOM_DEPS_DEV_API=https://api.deps.dev/v3alpha
SBOM_ANACONDA_API=https://api.anaconda.org
SBOM_EOL_API=https://endoflife.date/api


# ------------------------------------------------------------
# API SERVER SETTINGS
# ------------------------------------------------------------
# CORS allowed origins (comma-separated list, or * for all)
SBOM_CORS_ORIGINS=*
# API server port
SBOM_API_PORT=8000
# API server host
SBOM_API_HOST=0.0.0.0
# ------------------------------------------------------------
# PERFORMANCE SETTINGS
# ------------------------------------------------------------
# Rate limit delay between API requests (seconds)
SBOM_RATE_LIMIT_DELAY=0.1
# Maximum retry attempts for failed API calls
SBOM_MAX_RETRIES=3
# API request timeout (seconds)
SBOM_API_TIMEOUT=30
# Thread pool size for parallel operations
SBOM_MAX_WORKERS=10

# ------------------------------------------------------------
# CACHING
# ------------------------------------------------------------
# Enable API response caching (true/false)
SBOM_ENABLE_CACHING=true
# LRU cache size
SBOM_CACHE_SIZE=2048
# Cache TTL in seconds (3600 = 1 hour)
SBOM_CACHE_TTL=3600
# Cache strategy: api_first (API first, DB fallback) or cache_first (DB first, API fallback)
SBOM_CACHE_STRATEGY=api_first

# ------------------------------------------------------------
# DATABASE (MySQL) - For persistent cache storage
# ------------------------------------------------------------
# Database host
SBOM_DB_HOST=localhost
# Database port
SBOM_DB_PORT=3306
# Database user
SBOM_DB_USER=root
# Database password (set your MySQL root password here)
SBOM_DB_PASSWORD=
# Database name
SBOM_DB_NAME=stacksq_scanner
# ------------------------------------------------------------
# SCANNING OPTIONS
# ------------------------------------------------------------
# Primary vulnerability source: osv or nvd
SBOM_VULN_SOURCE=osv
# Include transitive dependencies (true/false)
SBOM_INCLUDE_TRANSITIVE=true
# Days to consider a package "recently published"
SBOM_RECENT_DAYS=7
# Skip examples/ directories (true/false)
SBOM_SKIP_EXAMPLES=true
# Skip tests/ directories (true/false)
SBOM_SKIP_TESTS=true
# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SBOM_LOG_LEVEL=INFO
# Log format string
SBOM_LOG_FORMAT=[%(levelname)s] %(message)s
# Log file path (leave empty for stdout only)
SBOM_LOG_FILE=