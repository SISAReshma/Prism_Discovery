# ── API Keys ──────────────────────────────────────────────────────────
# HuggingFace Hub token (required for model card lookups)
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE

# Groq API key (required for LLM validation & categorization)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# ── LLM Settings ──────────────────────────────────────────────────────
GROQ_MODEL=openai/gpt-oss-20b
LLM_MIN_TOKENS=1000
LLM_MAX_TOKENS=4000
LLM_TOKENS_PER_LIBRARY=70
